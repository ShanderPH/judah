# Django
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Redis
REDIS_URL=redis://localhost:6379/0

# AI
# Default is false; set to true to mount /api/v1/ai/*.
AI_ROUTING_ENABLED=false
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=gpt-4o
DEFAULT_MINI_MODEL=gpt-4o-mini
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=inchurch-knowledge
PINECONE_HOST=https://your-index.svc.aped-4627-b74a.pinecone.io
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1536
# NOTE: the Pinecone integration client currently hard-codes text-embedding-3-small.
EMBEDDING_MODEL=text-embedding-ada-002
SALOMAO_V1_BASE_URL=http://localhost:8001
SALOMAO_V1_TIMEOUT_SECONDS=45
SALOMAO_V1_IMAGE_TIMEOUT_SECONDS=180
SALOMAO_V1_AS_TEAM_AGENT=true
USE_MOCK_HUBSPOT=false
AGNO_TELEMETRY=false

# HubSpot
HUBSPOT_ACCESS_TOKEN=your-hubspot-token
HUBSPOT_APP_SECRET=your-app-secret
HUBSPOT_PORTAL_ID=your-portal-id
HUBSPOT_N1_TEAM_ID=8
HUBSPOT_SALOMAO_SENDER_ACTOR_ID=A-123456
HUBSPOT_AI_TRIAGE_STAGE_ID=
HUBSPOT_AI_REPLY_DISABLED_CHANNELS=
HUBSPOT_IMAGE_MAX_BYTES=8388608
HUBSPOT_TICKET_CHURCH_PROPERTY=codigo_de_igreja_local___ticket

# Jira
JIRA_SERVER_URL=https://inchurch.atlassian.net
JIRA_API_TOKEN=your-jira-token
JIRA_USER_EMAIL=your-email@inchurch.com.br
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret

# Sentry
SENTRY_DSN=https://xxxx@sentry.io/xxxx
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.01
GIT_SHA=local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.inchurch.com.br

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Railway-only fallback (optional)
# REDIS_PRIVATE_URL=redis://localhost:6379/0
