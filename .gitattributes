# Normalize line endings to LF on commit (cross-platform consistency)
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# Config files
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
Makefile text eol=lf

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
